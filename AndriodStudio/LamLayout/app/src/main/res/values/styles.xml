<resources>
    
    <style name="DialogButton.Positive" parent="Widget.AppCompat.Button.Colored">
        <item name="android:backgroundTint">@color/color_button_positive</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
    </style>

    <style name="DialogButton.Negative" parent="Widget.AppCompat.Button.Borderless.Colored">
        <item name="android:textColor">@color/color_button_negative</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <!-- Фон диалога -->
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        
        <!-- Цвет заголовка и текста -->
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/darker_gray</item>
        
    </style>

</resources>